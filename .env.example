# Copy to .env.local and fill in your values (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
YOUTUBE_API_KEY=your-youtube-api-key

# LiveKit — https://cloud.livekit.io
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# DeepAR — face lenses & background blur on live video (free dev key)
# https://developer.deepar.ai/
NEXT_PUBLIC_DEEPAR_LICENSE_KEY=your-deepar-license-key

# ── Zumelia AI (Groq — free tier) ─────────────────────────────────────────────
# Get a key at https://console.groq.com (no credit card required)
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Transactional email (Resend — https://resend.com) ───────────────────────
# Verify your sending domain in Resend, then use e.g. Zumelia <notifications@yourdomain.com>
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Zumelia <notifications@yourdomain.com>
NEXT_PUBLIC_APP_URL=https://zumelia.vercel.app

# Protects /api/cron/birthday-emails (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-string

# ── Payments (Paystack) ───────────────────────────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_test_...
