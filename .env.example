# Copy to .env.local and fill in your values (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
YOUTUBE_API_KEY=your-youtube-api-key

# LiveKit — https://cloud.livekit.io
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# DeepAR — face lenses & background blur on live video (free dev key)
# https://developer.deepar.ai/
# Keys are tied to the domain you register — create one web app per domain:
#   Production: itunes-mu.vercel.app  → NEXT_PUBLIC_DEEPAR_LICENSE_KEY
#   Local dev:  localhost              → NEXT_PUBLIC_DEEPAR_LICENSE_KEY_LOCAL (optional)
NEXT_PUBLIC_DEEPAR_LICENSE_KEY=your-deepar-license-key
NEXT_PUBLIC_DEEPAR_LICENSE_KEY_LOCAL=your-localhost-deepar-key

# ── Zumelia AI (Groq — free tier) ─────────────────────────────────────────────
# Get a key at https://console.groq.com (no credit card required)
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Transactional email (Resend — https://resend.com) ───────────────────────
# 1. Buy your domain (e.g. zumelia.app) and add it in Resend → Domains
# 2. Add SPF/DKIM DNS records → wait for status "verified"
# 3. Use that domain below (not onboarding@resend.dev for real users)
# Check setup: npm run email:verify-setup
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Zumelia <notifications@yourdomain.com>
# Canonical production URL (emails, cron). OAuth uses the browser origin automatically.
NEXT_PUBLIC_APP_URL=https://itunes-mu.vercel.app

# Optional override for Android APK (defaults to GitHub Releases Zumelia.apk)
# NEXT_PUBLIC_ANDROID_APK_URL=https://github.com/Femi1245/femistore/releases/latest/download/Zumelia.apk

# Protects /api/cron/* routes (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-string

# Supabase Database Webhook → POST /api/push/dispatch (notifications INSERT)
# Header: Authorization: Bearer <PUSH_WEBHOOK_SECRET>
PUSH_WEBHOOK_SECRET=generate-a-long-random-string
# Optional — higher Expo push rate limits
# EXPO_ACCESS_TOKEN=

# Owner-only admin dashboard (comma-separated for multiple)
ZUMELIA_OWNER_EMAIL=olaniranfemi01@gmail.com
# Support inbox — where contact form messages are delivered (defaults to ZUMELIA_OWNER_EMAIL)
SUPPORT_EMAIL=olaniranfemi01@gmail.com
# ZUMELIA_OWNER_USERNAME=femisaint
# ZUMELIA_OWNER_USER_ID=your-profile-uuid

# ── Payments (Paystack) ───────────────────────────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_test_...
