EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Deployed Next.js API (live tokens, calls, YouTube search)
EXPO_PUBLIC_API_URL=https://itunes-mu.vercel.app

# ── Supabase Auth (required for APK) ─────────────────────────────────────────
# Supabase → Authentication → URL Configuration → Redirect URLs — add:
#   zumelia://auth/callback
#
# This lets Google/GitHub/X sign-in return to the native app (not the browser).
# Expo Go dev builds may also need the exp:// URL printed in Metro logs.
#
# Full APK build guide: ../MOBILE_APK.md
