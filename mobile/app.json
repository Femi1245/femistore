{
  "expo": {
    "name": "Zumelia",
    "slug": "zumelia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zumelia",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4e8d4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zumelia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f4e8d4"
      },
      "package": "com.zumelia.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zumelia to access your photos for posts and profile pictures."
        }
      ],
      "expo-web-browser",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
